{
  "name": "social-activities-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Social Activities SPA — React-compatible Preact + Vite + TypeScript over Django/DRF.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && npm run check:bundle",
