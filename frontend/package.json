    "test": "node tests/contracts.test.mjs"
  },
  "dependencies": {
    "@roedu/ui": "file:vendor/roedu-ui-0.3.0.tgz",
    "preact": "^10.29.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
