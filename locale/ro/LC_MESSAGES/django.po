msgstr "Activități viitoare"

#: apps/web/templates/web/activities.html:6
#, python-format
msgid "In your cohort (<strong>%(cohort)s</strong>)."
msgstr "În cohorta ta (<strong>%(cohort)s</strong>)."

#: apps/web/templates/web/activities.html:7
