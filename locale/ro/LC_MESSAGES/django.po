#: apps/web/templates/web/access_preferences.html:3
#: apps/web/templates/web/access_preferences.html:5
msgid "Access preferences"
msgstr "Preferințe de accesibilitate"

#: apps/web/templates/web/access_preferences.html:6
msgid ""
"A setting you choose &mdash; we never track or infer it. We only ever show "
"what a venue's open data records, and places with unknown accessibility are "
"still shown to you."
msgstr ""
"O setare pe care o alegi tu &mdash; nu o urmărim și nu o deducem niciodată. "
"Afișăm doar ceea ce înregistrează datele deschise ale unei locații, iar "
"locurile cu accesibilitate necunoscută îți sunt în continuare afișate."

#: apps/web/templates/web/access_preferences.html:10
msgid "I need step-free access"
msgstr "Am nevoie de acces fără trepte"

#: apps/web/templates/web/access_preferences.html:14
msgid "I need an accessible toilet"
msgstr "Am nevoie de o toaletă accesibilă"

#: apps/web/templates/web/access_preferences.html:18
msgid "I prefer quiet / sensory-friendly places"
msgstr "Prefer locuri liniștite / prietenoase senzorial"

#: apps/web/templates/web/access_preferences.html:19
msgid ""
"Saved for the future &mdash; venue data for this isn't available yet, so it "
"doesn't change what you see."
msgstr ""
"Salvat pentru viitor &mdash; datele locațiilor pentru aceasta nu sunt încă "
"disponibile, deci nu schimbă ceea ce vezi."

#: apps/web/templates/web/access_preferences.html:21
msgid "Save preferences"
msgstr "Salvează preferințele"

#: apps/web/templates/web/activities.html:3
#: apps/web/templates/web/activity_detail.html:5 templates/base.html:16
