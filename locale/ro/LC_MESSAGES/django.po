#: apps/web/templates/web/activities.html:8
#: apps/web/templates/web/home.html:39
msgid "beginners welcome only"
msgstr "doar pentru începători"

#: apps/web/templates/web/activities.html:11
#: apps/web/templates/web/home.html:43
msgid "Nothing upcoming yet. Be the first to organise something!"
msgstr "Nimic în curând încă. Fii primul care organizează ceva!"

#: apps/web/templates/web/activity_detail.html:17
#: apps/web/templates/web/event_detail.html:9
#, python-format
msgid "at <a href=\"%(place_url)s\">%(place_name)s</a>"
msgstr "la <a href=\"%(place_url)s\">%(place_name)s</a>"

#: apps/web/templates/web/activity_detail.html:19
msgid "Part of:"
msgstr "Face parte din:"

#: apps/web/templates/web/activity_detail.html:23
msgid "Accessibility:"
msgstr "Accesibilitate:"

#: apps/web/templates/web/activity_detail.html:24
#, python-format
msgid "Organised by %(owner_name)s."
msgstr "Organizat de %(owner_name)s."

#: apps/web/templates/web/activity_detail.html:25
#: apps/web/templates/web/report.html:3
msgid "Report"
msgstr "Raportează"

#: apps/web/templates/web/activity_detail.html:28
#, python-format
msgid "This activity is %(status_display)s."
msgstr "Această activitate este %(status_display)s."

#: apps/web/templates/web/activity_detail.html:29
msgid "The organiser called it off &mdash; see your alerts for any details."
msgstr "Organizatorul a anulat-o &mdash; vezi alertele tale pentru detalii."

#: apps/web/templates/web/activity_detail.html:34
msgid "Organiser tools"
msgstr "Instrumente pentru organizator"

#: apps/web/templates/web/activity_detail.html:36
msgid "Edit details"
msgstr "Editează detaliile"

#: apps/web/templates/web/activity_detail.html:39
msgid "Cancel this activity? Every member will be notified."
msgstr "Anulezi această activitate? Fiecare membru va fi notificat."

#: apps/web/templates/web/activity_detail.html:41
msgid "Cancel this activity"
msgstr "Anulează această activitate"

#: apps/web/templates/web/activity_detail.html:43
msgid "Optional: why (members will see this)"
msgstr "Opțional: de ce (membrii vor vedea asta)"

#: apps/web/templates/web/activity_detail.html:44
msgid "Cancel activity"
msgstr "Anulează activitatea"

#: apps/web/templates/web/activity_detail.html:51
msgid "You're a member"
msgstr "Ești membru"

#: apps/web/templates/web/activity_detail.html:51
msgid "(owner)"
msgstr "(organizator)"

#: apps/web/templates/web/activity_detail.html:54
msgid "Leave"
msgstr "Părăsește"

#: apps/web/templates/web/activity_detail.html:58
msgid "I've arrived"
msgstr "Am ajuns"

#: apps/web/templates/web/activity_detail.html:59
msgid "Tells the group you're here &mdash; no location shared."
msgstr "Anunță grupul că ești aici &mdash; nu se partajează nicio locație."

#: apps/web/templates/web/activity_detail.html:62
#, python-format
msgid ""
"You marked yourself here at %(arrival_time)s &mdash; your group was "
"notified."
msgstr ""
"Te-ai marcat ca prezent la %(arrival_time)s &mdash; grupul tău a fost "
"notificat."

#: apps/web/templates/web/activity_detail.html:65
#, python-format
msgid "Coming: <strong>%(going)s</strong> of %(total)s"
msgstr "Vin: <strong>%(going)s</strong> din %(total)s"

#: apps/web/templates/web/activity_detail.html:70
