msgstr "&#10003; Consimțământul parental este activ."

msgid "&bull; Parental consent is not active."
msgstr "&bull; Consimțământul parental nu este activ."

msgid "You can grant or revoke it."
msgstr "Îl poți acorda sau revoca."

msgid ""
