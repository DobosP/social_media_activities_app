#: apps/web/templates/web/_post.html:55
msgid "Delete your message? This can\\'t be undone."
msgstr "Ștergi mesajul? Această acțiune nu poate fi anulată."

#: apps/web/templates/web/_post.html:56
msgid "Delete"
msgstr "Șterge"

#: apps/web/templates/web/_post.html:61
msgid "Edit your message"
