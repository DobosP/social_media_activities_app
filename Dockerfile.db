# PostGIS + pgvector database image for local/dev.
#
# The base postgis image lacks the `vector` (pgvector) extension the app's
# migrations require; we add the package here. This image must not load schema or
# data through `/docker-entrypoint-initdb.d/`: Django migrations are the only
# schema authority, and RO-EDU demo data loads from the web container after
# `manage.py migrate`.
FROM postgis/postgis:16-3.4

RUN apt-get update \
    && apt-get install -y --no-install-recommends postgresql-16-pgvector \
    && rm -rf /var/lib/apt/lists/*
