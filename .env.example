# Copy to .env for local (non-Docker) runs. Docker Compose sets these itself.
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-prod
DATABASE_URL=postgis://app:app@localhost:5432/app

# Ingestion
OVERPASS_URL=https://overpass-api.de/api/interpreter
INGEST_DEFAULT_CITY=Cluj-Napoca
INGEST_USER_AGENT=social-activities-app/0.1 (nonprofit; contact: you@example.org)

# --- Production integrations (config.settings.prod; all optional in dev) ---
# EUDI age verification (D2): turn the sandbox off and trust the live EU issuer(s).
# EUDI_SANDBOX=False
# EUDI_TRUSTED_ISSUERS={"https://issuer.example.eu":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}

# Media object storage (S3-compatible: AWS S3 / Cloudflare R2 / MinIO).
# MEDIA_STORAGE_BACKEND=apps.media.storage.S3StorageBackend
# MEDIA_S3_BUCKET=
# MEDIA_S3_ENDPOINT_URL=        # e.g. https://<account>.r2.cloudflarestorage.com (R2/MinIO)
# MEDIA_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Content-safety scanning (uploads are FAIL-CLOSED in prod: disabled until an *effective*
# scanner is configured). Pick ONE path to enable photo uploads:
#  (a) a hash blocklist — inline and/or a newline-delimited file of known-bad SHA-256s:
# MEDIA_CSAM_HASH_BLOCKLIST=<hash1>,<hash2>
# MEDIA_CSAM_HASH_BLOCKLIST_FILE=/secrets/csam-hashes.txt
#  (b) a managed matcher (PhotoDNA/Thorn-style HTTPS endpoint):
# MEDIA_IMAGE_SCANNER=apps.media.scanning.ManagedHttpScanner
# MEDIA_SCANNER_ENDPOINT=https://scanner.example/scan
# MEDIA_SCANNER_API_KEY=
# Decompression-bomb ceiling (header-declared pixels rejected before decode):
# MEDIA_MAX_IMAGE_PIXELS=30000000

# Donations via Stripe Checkout (no card data touched).
# DONATIONS_PROVIDER=apps.donations.providers.StripePaymentProvider
# STRIPE_SECRET_KEY=
# DONATIONS_SUCCESS_URL=https://your-host/thanks
# DONATIONS_CANCEL_URL=https://your-host/donate
# Donation-webhook auth (FAIL-CLOSED: with neither set, webhook callbacks are rejected).
# DONATIONS_WEBHOOK_SECRET=        # shared secret sent in X-Webhook-Secret
# STRIPE_WEBHOOK_SECRET=           # Stripe signing secret (verifies Stripe-Signature)
