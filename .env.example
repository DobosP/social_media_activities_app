# Copy to .env for local (non-Docker) runs. Docker Compose sets these itself.
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-prod
DATABASE_URL=postgis://app:app@localhost:5432/app

# Ingestion
OVERPASS_URL=https://overpass-api.de/api/interpreter
INGEST_DEFAULT_CITY=Cluj-Napoca
INGEST_USER_AGENT=social-activities-app/0.1 (nonprofit; contact: you@example.org)

# --- Production integrations (config.settings.prod; all optional in dev) ---
# EUDI age verification (D2): turn the sandbox off and trust the live EU issuer(s).
# EUDI_SANDBOX=False
# EUDI_TRUSTED_ISSUERS={"https://issuer.example.eu":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}

# Media object storage (S3-compatible: AWS S3 / Cloudflare R2 / MinIO).
# MEDIA_STORAGE_BACKEND=apps.media.storage.S3StorageBackend
# MEDIA_S3_BUCKET=
# MEDIA_S3_ENDPOINT_URL=        # e.g. https://<account>.r2.cloudflarestorage.com (R2/MinIO)
# MEDIA_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Donations via Stripe Checkout (no card data touched).
# DONATIONS_PROVIDER=apps.donations.providers.StripePaymentProvider
# STRIPE_SECRET_KEY=
# DONATIONS_SUCCESS_URL=https://your-host/thanks
# DONATIONS_CANCEL_URL=https://your-host/donate
